FROM ruby:3.3-alpine

# Install development dependencies including Python and uv
RUN apk add --no-cache \
    bash \
    build-base \
    postgresql-dev \
    libffi-dev \
    yaml-dev \
    git \
    curl \
    bash \
    python3 \
    py3-pip \
    python3-dev \
    uv

# Create non-root user for security
RUN addgroup -g 1000 -S app && \
    adduser -u 1000 -S app -G app

# Set working directory  
WORKDIR /app

# Copy Gemfile, gemspec and install gems
COPY --chown=1000:1000 Gemfile Gemfile.lock blueprintsCLI.gemspec ./
COPY --chown=1000:1000 lib/blueprintsCLI/version.rb ./lib/blueprintsCLI/

RUN bundle config set --local without 'test' && \
    bundle install --jobs 4 --retry 3

# Copy application code
COPY . .

# Create directories and set ownership
RUN mkdir -p log tmp && \
    chown -R app:app /app

# Switch to non-root user
USER app

RUN uv venv .venv && \
    source .venv/bin/activate && \
    uv pip install --no-cache-dir --upgrade pip setuptools && \
    uv pip install --no-cache-dir spacy numpy

# Activate virtual environment for all subsequent commands and processes
ENV VIRTUAL_ENV=/app/.venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

# Expose port 3000 and debug port
EXPOSE 3000
EXPOSE 9229

# For development, we'll mount the code as a volume
# and use rerun for auto-reloading
CMD ["bundle", "exec", "rerun", "--background", "--signal", "TERM", "rackup lib/blueprintsCLI/web_config.ru -o 0.0.0.0 -p 3000"]