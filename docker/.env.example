# BlueprintsCLI Docker Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database Settings
POSTGRES_DB=blueprints_cli_production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Development Database Settings (used in dev environment)
POSTGRES_DEV_DB=blueprints_development
POSTGRES_DEV_USER=postgres
POSTGRES_DEV_PASSWORD=dev_password

# Database Ports
POSTGRES_PORT=5432
POSTGRES_DEV_PORT=5433

# =============================================================================
# REDIS CONFIGURATION  
# =============================================================================

# Redis Settings
REDIS_PORT=6379
REDIS_DEV_PORT=6380

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Security Settings
JWT_SECRET=change_this_jwt_secret_in_production
SESSION_SECRET=change_this_session_secret_in_production

# AI Service Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Nginx Ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Application Ports
FRONTEND_DEV_PORT=8080
BACKEND_DEV_PORT=3000
RUBY_DEBUG_PORT=9229

# Development Tools Ports
NGINX_DEV_PORT=8000
ADMINER_PORT=8081
MAILCATCHER_WEB_PORT=1080
MAILCATCHER_SMTP_PORT=1025

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Data Directory (for persistent volumes)
DATA_DIR=./data

# =============================================================================
# MONITORING & OBSERVABILITY (Optional)
# =============================================================================

# Grafana Configuration
GRAFANA_PASSWORD=admin

# =============================================================================
# DEVELOPMENT ENVIRONMENT VARIABLES
# =============================================================================

# Log Levels
LOG_LEVEL=info
DEV_LOG_LEVEL=debug

# Development Features
ENABLE_CORS=true
ENABLE_LOGGING=true
PRETTY_LOGGING=true

# =============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================

# Performance Configuration
RUBY_GC_MALLOC_LIMIT=16000000
RUBY_GC_HEAP_GROWTH_FACTOR=1.1

# Resource Limits (for compose deploy configuration)
BACKEND_MEMORY_LIMIT=512M
BACKEND_MEMORY_RESERVATION=256M
POSTGRES_MEMORY_LIMIT=1G
POSTGRES_MEMORY_RESERVATION=512M
REDIS_MEMORY_LIMIT=512M
REDIS_MEMORY_RESERVATION=256M