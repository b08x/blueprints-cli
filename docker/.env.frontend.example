# Frontend Service Configuration
# Copy this file to .env and customize for your environment

# Frontend service port (production)
FRONTEND_PORT=8080

# Frontend development service port
FRONTEND_DEV_PORT=8080

# Build-time configuration
FRONTEND_BUILD_ENV=production

# API endpoint configuration (used by frontend JavaScript)
API_BASE_URL=http://localhost:3000/api

# Feature flags
ENABLE_ANALYTICS=false
ENABLE_DEBUG_MODE=false

# CDN and external service configuration
TAILWIND_CDN_URL=https://cdn.tailwindcss.com
GOOGLE_FONTS_URL=https://fonts.googleapis.com

# Security headers customization
CSP_SCRIPT_SRC="'self' https://cdn.tailwindcss.com 'unsafe-inline'"
CSP_STYLE_SRC="'self' https://cdn.tailwindcss.com https://fonts.googleapis.com 'unsafe-inline'"
CSP_FONT_SRC="'self' https://fonts.gstatic.com data:"

# Performance settings
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024
NGINX_KEEPALIVE_TIMEOUT=65