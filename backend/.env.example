# Database Configuration
DATABASE_URL=postgres://postgres:blueprints@localhost:5432/blueprintscli_development

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-use-at-least-32-characters

# AI Service Configuration (optional)
AI_SERVICE_URL=http://localhost:8080
AI_SERVICE_API_KEY=your-ai-service-api-key
AI_SERVICE_TIMEOUT=30
AI_SERVICE_RETRIES=3

# Rate Limiting Configuration
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# Logging Configuration
LOG_LEVEL=info

# Application Configuration
RACK_ENV=development
PORT=4000

# For production, set these to appropriate values:
# DATABASE_URL=postgres://user:password@localhost:5432/blueprintscli_production
# REDIS_URL=redis://localhost:6379/0
# JWT_SECRET=generated-secure-random-string-at-least-32-characters-long
# LOG_LEVEL=warn
# RACK_ENV=production